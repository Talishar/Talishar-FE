{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard"
  ],
  "timezone": "Etc/UTC",
  "schedule": ["before 5am on monday"],
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "description": "All patch updates (prod + dev) -> one grouped PR every Monday.",
      "matchUpdateTypes": ["patch"],
      "groupName": "weekly patch updates",
      "schedule": ["before 5am on monday"]
    },
    {
      "description": "All minor updates (prod + dev) -> one grouped PR every Monday.",
      "matchUpdateTypes": ["minor"],
      "groupName": "weekly minor updates",
      "schedule": ["before 5am on monday"]
    },
    {
      "description": "All majors -> NO PR. Parked on the Dependency Dashboard; tick the checkbox there to open one when ready.",
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    }
  ]
}